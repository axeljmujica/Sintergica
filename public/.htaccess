<IfModule mod_rewrite.c>
  RewriteEngine On

  # Definir documento por defecto
  DirectoryIndex index.html

  # Redirecciones legadas
  RewriteRule ^investigacion/blog/?$ /recursos/blog/ [R=301,L]
  RewriteRule ^investigacion/prensa/?$ /recursos/prensa/ [R=301,L]
  RewriteRule ^empresa/eventos/?$ /recursos/eventos/ [R=301,L]

  # Redirigir /es/ visible a la raíz para SEO
  RewriteCond %{THE_REQUEST} \s/es/ [NC]
  RewriteRule ^es/(.*)$ /$1 [R=301,L]
  RewriteRule ^es$ / [R=301,L]

  # 1. Si el archivo o directorio físico existe, servirlo directamente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2. Forzar trailing slash para que busque dentro del directorio generado por Next.js
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !(\.[a-zA-Z0-9]{2,5})$
  RewriteCond %{REQUEST_URI} !(.*)/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]

  # 3. Enrutar idiomas: por defecto sirve /es/ internamente para las rutas en la raíz
  RewriteCond %{REQUEST_URI} !^/(es|en|pt-br)/
  RewriteCond %{REQUEST_URI} !^/_next/
  RewriteCond %{REQUEST_URI} !(\.[a-zA-Z0-9]{2,5})$
  RewriteRule ^(.*)$ /es/$1 [L]

</IfModule>

<IfModule mod_mime.c>
  # Correct MIME types
  AddType font/woff2 .woff2
</IfModule>

# Manejo de error 404
ErrorDocument 404 /404.html
